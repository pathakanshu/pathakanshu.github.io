---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "About | Anshu Pathak";

const skillSlugs: Record<string, string> = {
    React: "react",
    TypeScript: "typescript",
    JavaScript: "javascript",
    Python: "python",
    "Node.js": "nodedotjs",
    "HTML/CSS": "html5",
    HTML: "html5",
    CSS: "css3",
    "CSS Architecture": "css3",
    Django: "django",
    APIs: "insomnia",
    PostgreSQL: "postgresql",
    MongoDB: "mongodb",
    Docker: "docker",
    Git: "git",
    GitHub: "github",
    Astro: "astro",
    Vue: "vuedotjs",
    Angular: "angular",
    Express: "express",
    FastAPI: "fastapi",
    REST: "postman",
    "Unix/Linux": "linux",
    "Vercel/Cloudflare": "vercel",
};

function getSlug(skill: string): string {
    const trimmed = skill.trim();
    if (skillSlugs[trimmed]) return skillSlugs[trimmed];

    for (const key in skillSlugs) {
        if (trimmed.toLowerCase().startsWith(key.toLowerCase())) {
            return skillSlugs[key];
        }
    }

    if (trimmed.includes("/")) {
        const firstPart = trimmed.split("/")[0].trim();
        return skillSlugs[firstPart] || "codeforces";
    }

    return "codeforces";
}

const skills = {
    frontend: ["React", "TypeScript", "Astro", "CSS Architecture"],
    backend: ["Python", "Node.js", "REST APIs", "PostgreSQL"],
    systems: ["Git/GitHub", "Docker Basics", "Unix/Linux", "Vercel/Cloudflare"],
};
---

<BaseLayout pageTitle={pageTitle}>
    <section class="page-header">
        <span class="hero-subtitle">Profile</span>
        <h1>Engineering the Future.</h1>
        <p>
            I'm a Software Engineering student focused on building performant,
            robust, and highly polished digital experiences. I believe great
            code should look as good as it works.
        </p>
    </section>

    <section class="about-grid">
        <article class="panel">
            <h2>My Approach</h2>
            <p>
                My work spans the full stack, but my philosophy remains the
                same: simplify complexity, write maintainable architecture, and
                prioritize the user experience above all else.
            </p>
            <p>
                Currently based in Pennsylvania, I spend my time exploring
                modern frameworks, optimizing backend services, and studying the
                art of interaction design.
            </p>
        </article>

        <aside class="panel">
            <h2>Vitals</h2>
            <ul class="facts-list">
                <li>
                    <span>Location</span>
                    <strong>Pennsylvania, USA</strong>
                </li>
                <li>
                    <span>Degree</span>
                    <strong>B.S. Software Engineering</strong>
                </li>
                <li>
                    <span>Class of</span>
                    <strong>2029</strong>
                </li>
                <li>
                    <span>Focus</span>
                    <strong>Systems & Design</strong>
                </li>
            </ul>
        </aside>
    </section>

    <section class="panel">
        <h2>Technical Arsenal</h2>
        <div class="skills-grid">
            <div class="skill-category">
                <h3>Frontend</h3>
                <div class="skill-group">
                    {
                        skills.frontend.map((skill) => (
                            <span class="skill-tag">
                                <img
                                    src={`https://cdn.simpleicons.org/${getSlug(skill)}/EDEDED`}
                                    width="16"
                                    height="16"
                                    alt={skill}
                                />
                                {skill}
                            </span>
                        ))
                    }
                </div>
            </div>

            <div class="skill-category">
                <h3>Backend</h3>
                <div class="skill-group">
                    {
                        skills.backend.map((skill) => (
                            <span class="skill-tag">
                                <img
                                    src={`https://cdn.simpleicons.org/${getSlug(skill)}/EDEDED`}
                                    width="16"
                                    height="16"
                                    alt={skill}
                                />
                                {skill}
                            </span>
                        ))
                    }
                </div>
            </div>

            <div class="skill-category">
                <h3>Systems</h3>
                <div class="skill-group">
                    {
                        skills.systems.map((skill) => (
                            <span class="skill-tag">
                                <img
                                    src={`https://cdn.simpleicons.org/${getSlug(skill)}/EDEDED`}
                                    width="16"
                                    height="16"
                                    alt={skill}
                                />
                                {skill}
                            </span>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <section class="panel cta">
        <h2>Want to know more?</h2>
        <p>
            I'm actively seeking internships and looking to collaborate on
            ambitious projects. Let's connect.
        </p>
        <div class="actions">
            <a href="/contact" class="btn btn-primary">Get in Touch</a>
            <a
                href="https://github.com/pathakanshu"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-secondary">View GitHub</a
            >
        </div>
    </section>
</BaseLayout>

<style>
    .facts-list {
        list-style: none;
        display: grid;
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .facts-list li {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .facts-list span {
        font-family: var(--font-sans);
        font-size: 0.8rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .facts-list strong {
        font-size: 1.1rem;
        color: var(--text-primary);
        font-weight: 500;
    }

    .skill-category h3 {
        margin-bottom: 1rem;
        color: var(--text-primary);
        font-size: 1.25rem;
    }

    .skill-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .skill-tag img {
        opacity: 0.8;
        transition: opacity 0.2s ease;
    }

    .skill-tag:hover img {
        opacity: 1;
    }

    :global(.light) .skill-tag img {
        filter: invert(1);
    }
</style>
