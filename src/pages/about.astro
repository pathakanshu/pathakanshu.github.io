---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "About | Anshu Pathak";
---

<BaseLayout pageTitle={pageTitle}>
    <section class="page-header">
        <span class="hero-subtitle">Profile</span>
        <h1>Engineering the Future.</h1>
        <p>
            I’m a Software Engineering student focused on building performant,
            robust, and highly polished digital experiences. I believe great
            code should look as good as it works.
        </p>
    </section>

    <section class="about-grid">
        <article class="panel">
            <h2>My Approach</h2>
            <p>
                My work spans the full stack, but my philosophy remains the
                same: simplify complexity, write maintainable architecture, and
                prioritize the user experience above all else.
            </p>
            <p>
                Currently based in Pennsylvania, I spend my time exploring
                modern frameworks, optimizing backend services, and studying the
                art of interaction design.
            </p>
        </article>

        <aside class="panel">
            <h2>Vitals</h2>
            <ul class="facts-list">
                <li>
                    <span>Location</span>
                    <strong>Pennsylvania, USA</strong>
                </li>
                <li>
                    <span>Degree</span>
                    <strong>B.S. Software Engineering</strong>
                </li>
                <li>
                    <span>Class of</span>
                    <strong>2029</strong>
                </li>
                <li>
                    <span>Focus</span>
                    <strong>Systems & Design</strong>
                </li>
            </ul>
        </aside>
    </section>

    <section class="panel">
        <h2>Technical Arsenal</h2>
        <div class="skills-grid">
            <div class="skill-category">
                <h3>Frontend</h3>
                <div class="skill-group">
                    <span class="skill-tag">TypeScript</span>
                    <span class="skill-tag">React</span>
                    <span class="skill-tag">Astro</span>
                    <span class="skill-tag">CSS Architecture</span>
                </div>
            </div>

            <div class="skill-category">
                <h3>Backend</h3>
                <div class="skill-group">
                    <span class="skill-tag">Python</span>
                    <span class="skill-tag">Node.js</span>
                    <span class="skill-tag">REST APIs</span>
                    <span class="skill-tag">PostgreSQL</span>
                </div>
            </div>

            <div class="skill-category">
                <h3>Systems</h3>
                <div class="skill-group">
                    <span class="skill-tag">Git/GitHub</span>
                    <span class="skill-tag">Docker Basics</span>
                    <span class="skill-tag">Unix/Linux</span>
                    <span class="skill-tag">Vercel/Cloudflare</span>
                </div>
            </div>
        </div>
    </section>

    <section class="panel cta">
        <h2>Want to know more?</h2>
        <p>
            I’m actively seeking internships and looking to collaborate on
            ambitious projects. Let’s connect.
        </p>
        <div class="actions">
            <a href="/contact" class="btn btn-primary">Get in Touch</a>
            <a
                href="https://github.com/pathakanshu"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-secondary">View GitHub</a
            >
        </div>
    </section>
</BaseLayout>

<style>
    .facts-list {
        list-style: none;
        display: grid;
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .facts-list li {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .facts-list span {
        font-family: var(--font-mono);
        font-size: 0.8rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .facts-list strong {
        font-size: 1.1rem;
        color: var(--text-primary);
        font-weight: 500;
    }

    .skill-category h3 {
        margin-bottom: 1rem;
        color: var(--text-primary);
        font-size: 1.25rem;
    }

    .skill-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
    }
</style>
