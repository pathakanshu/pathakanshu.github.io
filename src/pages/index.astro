---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectShowcase from "../components/ProjectShowcase.astro";
import projects from "../data/projects.json";

const pageTitle = "Anshu Pathak | Software Engineer";
---

<BaseLayout pageTitle={pageTitle}>
    <section class="hero-section">
        <div class="hero-grid">
            <div class="hero-copy">
                <span class="hero-subtitle">Software Engineering Student</span>
                <h1>Anshu Pathak</h1>
                <p>
                    I build sleek, high-performance web applications. Focused on
                    clean architecture, striking design, and robust engineering.
                </p>
                <div class="actions">
                    <a href="#projects" class="btn btn-primary">View Work</a>
                    <a href="/about" class="btn btn-secondary">About Me</a>
                </div>
            </div>

            <div class="hero-image" aria-label="Hero abstract image">
                <img
                    src="https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&w=800&q=80"
                    alt="Creative abstract coding visualization"
                    loading="eager"
                    decoding="async"
                />
            </div>
        </div>
    </section>

    <section id="projects">
        <div style="margin-bottom: 3rem;">
            <h2>Selected Works</h2>
            <p>
                A curated collection of my recent engineering and design
                projects.
            </p>
        </div>

        <div class="projects-section">
            {
                projects.projects.map((project: any) => (
                    <ProjectShowcase
                        ProjectName={project.name}
                        Image={project.image}
                        ImageAlt={project.name}
                        Skills={project.skills}
                    >
                        {project.description}
                    </ProjectShowcase>
                ))
            }
        </div>
    </section>

    <section class="panel cta">
        <h2>Let's build something exceptional.</h2>
        <p>
            I'm actively looking for internships, creative collaborations, and
            complex problems to solve. Reach out if you'd like to work together.
        </p>
        <div class="actions">
            <a href="/contact" class="btn btn-primary">Get in Touch</a>
            <a
                href="https://github.com/pathakanshu"
                target="_blank"
                rel="noopener noreferrer"
                class="btn btn-secondary">GitHub</a
            >
        </div>
    </section>
</BaseLayout>
