---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectShowcase from "../components/ProjectShowcase.astro";
import projects from "../data/projects.json";

const pageTitle = "Projects | Anshu Pathak";
---

<BaseLayout pageTitle={pageTitle}>
    <section class="page-header">
        <span class="hero-subtitle">Archive</span>
        <h1>Projects</h1>
        <p>
            A curated selection of my work spanning frontend interfaces, robust
            backend architectures, and experimental designs. Built with modern
            web technologies and a focus on performance.
        </p>
    </section>

    <section class="projects-section" aria-label="Project list">
        {
            projects.projects.map((project: any) => (
                <ProjectShowcase
                    ProjectName={project.name}
                    Image={project.image}
                    ImageAlt={project.name}
                    Skills={project.skills}
                >
                    {project.description}
                </ProjectShowcase>
            ))
        }

        {
            projects.projects.length === 0 && (
                <div class="panel empty-state">
                    <h2>No projects yet</h2>
                    <p>
                        I'm currently preparing detailed case studies. Check
                        back soon.
                    </p>
                </div>
            )
        }
    </section>

    <section class="panel cta">
        <h2>See something you like?</h2>
        <p>
            Whether you want to discuss a project, ask about my code, or just
            say hello, I'm always open to interesting conversations.
        </p>
        <div class="actions">
            <a href="/contact" class="btn btn-primary">Start a Conversation</a>
            <a href="/" class="btn btn-secondary">Back to Home</a>
        </div>
    </section>
</BaseLayout>

<style>
    .empty-state {
        text-align: center;
        padding: 6rem 2rem;
        border-style: dashed;
        border-color: var(--border-subtle);
    }

    .empty-state h2 {
        margin-bottom: 1rem;
        font-size: clamp(1.5rem, 3vw, 2rem);
    }

    .empty-state p {
        margin: 0 auto;
    }

    .cta {
        margin-top: 4rem;
        text-align: left;
    }
</style>
