---
import BaseLayout from "../Layouts/BaseLayout.astro";
import ProjectShowcase from "../components/ProjectShowcase.astro";
import projects from "../data/projects.json";
const pageTitle = "Projects";
---

<BaseLayout pageTitle={pageTitle}>
    <h1>Projects</h1>
    <p>
        Lorem ipsum dolor sit, amet consectetur adipisicing elit. Ullam deleniti
        dolore vel, iusto minima incidunt autem molestias repellat nemo fuga
        eius nostrum dicta praesentium accusamus consequatur culpa excepturi
        nulla distinctio.
    </p>
    <section class="projects-section">
        {
            projects.projects.map((project: any) => (
                <ProjectShowcase
                    ProjectName={project.name}
                    Image={project.image}
                    ImageAlt={project.image}
                    Skills={project.skills}
                >
                    {project.description}
                </ProjectShowcase>
            ))
        }
    </section>
    <div class="project-card"></div>
</BaseLayout>
