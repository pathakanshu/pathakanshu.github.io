---
const { ProjectName, Image, ImageAlt, Skills } = Astro.props;

const skillSlugs: Record<string, string> = {
    React: "react",
    TypeScript: "typescript",
    JavaScript: "javascript",
    Python: "python",
    "Node.js": "nodedotjs",
    "HTML/CSS": "html5",
    HTML: "html5",
    CSS: "css",
    "CSS Architecture": "css3",
    Django: "django",
    APIs: "insomnia",
    PostgreSQL: "postgresql",
    MongoDB: "mongodb",
    Docker: "docker",
    Git: "git",
    GitHub: "github",
    Astro: "astro",
    Vue: "vuedotjs",
    Angular: "angular",
    Express: "express",
    FastAPI: "fastapi",
    REST: "postman",
};

function getSlug(skill: string): string {
    const trimmed = skill.trim();

    // 1. Direct match
    if (skillSlugs[trimmed]) return skillSlugs[trimmed];

    // 2. Multi-word starts-with match (e.g., "CSS Architecture" -> "CSS")
    for (const key in skillSlugs) {
        if (trimmed.toLowerCase().startsWith(key.toLowerCase())) {
            return skillSlugs[key];
        }
    }

    // 3. Slash fallback (e.g., "HTML/CSS" -> "HTML")
    if (trimmed.includes("/")) {
        const firstPart = trimmed.split("/")[0].trim();
        return skillSlugs[firstPart] || "codeforces";
    }

    return "codeforces";
}
---

<article class="section-grid">
    <div class="section-text">
        <h3>{ProjectName}</h3>
        <p>
            <slot />
        </p>
        <div class="skills-list" aria-label="Project skills">
            {
                Skills.split(",").map((skill: string) => (
                    <span class="skill-tag">
                        <img
                            src={`https://cdn.simpleicons.org/${getSlug(skill)}/EDEDED`}
                            width="16"
                            height="16"
                            alt={skill.trim()}
                            class="skill-icon-img"
                        />
                        {skill.trim()}
                    </span>
                ))
            }
        </div>
    </div>

    <div class="section-img">
        <img src={Image} alt={ImageAlt} loading="lazy" />
    </div>
</article>

<style>
    .skill-icon-img {
        opacity: 0.8;
    }

    .section-grid:hover .skill-icon-img {
        opacity: 1;
        filter: none;
    }

    :global(.light) .skill-icon-img {
        filter: invert(1);
    }
</style>
