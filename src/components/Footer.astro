---
const currentYear = new Date().getFullYear();
---

<footer>
    <div class="footer-content">
        <p>&copy; {currentYear} Anshu Pathak. All rights reserved.</p>
        <p class="tagline">Designed & Engineered with precision.</p>
    </div>
</footer>

<style>
    .footer-content {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        align-items: center;
        justify-content: center;
    }

    p {
        margin: 0;
    }

    .tagline {
        color: var(--accent-gold);
        font-size: 0.75rem;
        opacity: 0.7;
    }
</style>
